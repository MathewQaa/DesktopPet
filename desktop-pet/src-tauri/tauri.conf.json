{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DesktopPet",
  "version": "0.1.0",
  "identifier": "com.mathewqaa.deskpet",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devUrl": "",
    "frontendDist": "../public"
  },
  "app": {
    "windows": [
      {
        "title": "DesktopPet",
        "width": 200,
        "height": 200,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "transparent": true,
        "fullscreen": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
